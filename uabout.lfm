  object RichMemo1: TRichMemo
    Left = 3
    Height = 351
    Top = 0
    Width = 582
    Color = clCream
    Font.Color = 3541000
    HideSelection = False
    Lines.Strings = (
      'MouseCatcher'
      ''
      'MouseCatcher is a Lazarus/LCL mouse diagnostic tool for analyzing cursor motion timing,'
      'button behavior and input irregularities.'
      ''
      'Designed for hardware diagnostics, RF dongle evaluation and performance comparison'
      'between wired and wireless devices.'
      ''
      'Features include:'
      '• Cursor tracking with tail visualization'
      '• Button state LEDs including extra buttons'
      '• Motion timing statistics (dt)'
      '• Histogram and latency charts'
      '• Drop detection (>25 ms / >50 ms)'
      ''
      ''
      'Author: Bo Gärdmark (SM6FIE)'
      'Gothenburg, Sweden'
      ''
      'License: MIT'
    )
    OnChange = RichMemo1Change
    ParentFont = False
    ScrollBars = ssAutoVertical
    TabOrder = 0
    ZoomFactor = 1
  end
